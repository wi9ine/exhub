{
  "name": "@exhub/upbit",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./zod/quotation": {
      "import": "./src/generated-zod/quotation/index.ts"
    },
    "./zod/exchange": {
      "import": "./src/generated-zod/exchange/index.ts"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm --dts --out-dir dist",
    "lint": "biome check .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:integration:private": "vitest run test/private.integration.test.ts --passWithNoTests"
  },
  "dependencies": {
    "@exhub/core": "workspace:*",
    "axios": "^1.12.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wi9ine/exhub.git",
    "directory": "packages/upbit"
  }
}
