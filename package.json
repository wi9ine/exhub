{
  "name": "exhub",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "generate": "pnpm exec orval --config ./scripts/orval.config.ts",
    "build": "pnpm -r --filter './core' --filter './packages/*' build",
    "lint": "pnpm -r --filter './core' --filter './packages/*' lint",
    "format": "pnpm -r --filter './core' --filter './packages/*' format",
    "format:check": "pnpm -r --filter './core' --filter './packages/*' format:check",
    "typecheck": "pnpm -r --filter './core' --filter './packages/*' typecheck",
    "test": "pnpm -r --filter './core' --filter './packages/*' test",
    "test:integration:private": "pnpm -r --filter './packages/*' test:integration:private"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@faker-js/faker": "^10.3.0",
    "@types/node": "^24.6.0",
    "axios": "^1.12.2",
    "dotenv": "^17.2.3",
    "orval": "^8.5.3",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
