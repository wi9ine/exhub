{
  "name": "exhub",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/wi9ine/exhub.git"
  },
  "scripts": {
    "generate": "pnpm exec orval --config ./scripts/orval.config.ts && node ./scripts/generate-mcp-tool-summaries.mjs",
    "build": "pnpm -r --filter './packages/*' --filter './apps/*' build",
    "lint": "pnpm -r --filter './packages/*' --filter './apps/*' lint",
    "format": "pnpm -r --filter './packages/*' --filter './apps/*' format",
    "format:check": "pnpm -r --filter './packages/*' --filter './apps/*' format:check",
    "typecheck": "pnpm -r --filter './packages/*' --filter './apps/*' typecheck",
    "test": "pnpm -r --filter './packages/*' --filter './apps/*' test",
    "test:integration:private": "pnpm -r --filter './packages/*' test:integration:private"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@faker-js/faker": "^10.3.0",
    "@types/node": "^24.6.0",
    "axios": "^1.12.2",
    "dotenv": "^17.2.3",
    "orval": "^8.5.3",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "zod": "^3.25.76"
  }
}
