              "type": "string",
              "example": "myOrder",
              "description": "고정 값 myOrder"
            },
            "order": {
              "type": "object",
              "properties": {
                "orders": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "orderId": {
                        "type": "integer",
                        "example": 123456,
                        "description": "주문 ID"
                      },
                      "status": {
                        "type": "string",
                        "example": "partiallyFilled",
                        "description": "주문 상태\n\n- pending 주문 접수 대기중. 잔고가 부족한 경우 주문이 실패해 expired 상태로 전환될 수 있습니다.\n\n- unfilled 전량 미체결 (REST API의 open 상태와 동일)\n\n- filled 전량 체결\n\n- canceled 전량 취소\n\n- partiallyFilled 부분 체결\n\n- partiallyFilledCanceled 부분 체결 후 잔량 취소\n\n- expired 주문 접수 실패",
                        "enum": [
                          "pending",
                          "unfilled",
                          "filled",
                          "canceled",
                          "partiallyFilled",
                          "partiallyFilledCanceled",
                          "expired"
                        ]
                      },
                      "side": {
                        "type": "string",
                        "example": "buy",
                        "description": "매수, 매도 구분\n\n- buy 매수\n\n- sell 매도",
                        "enum": ["buy", "sell"]
                      },
                      "orderType": {
                        "type": "string",
                        "example": "limit",
                        "description": "주문 유형 구분\n\n- limit 지정가 주문\n\n- market 시장가 주문\n\n- best BBO 주문 (Best-Bid-Offer, 최우선/최유리)",
                        "enum": ["limit", "market", "best"]
                      },
                      "timeInForce": {
                        "type": "string",
                        "example": "gtc",
                        "description": "주문 취소 조건\n\n- gtc 일반적인 지정가 주문. 전량 체결되거나 취소될 때까지 유효한 주문입니다. (Good-Till-Canceled)\n\n- ioc 주문호가 또는 더 좋은 가격으로 즉시 체결시킵니다. 체결되지 않은 잔량은 취소됩니다. (Immediate-Or-Cancel)\n\n- fok 주문호가 또는 더 좋은 가격으로 즉시 전량 체결시킵니다. 전량 체결이 불가하다면 주문이 취소됩니다. (Fill-Or-Kill)\n\n- po 주문 입력 시 바로 체결되는 상황이라면 주문이 취소됩니다. 즉, 메이커(Maker) 주문만 발생합니다. (Post-Only)",
                        "enum": ["gtc", "ioc", "fok", "po"]
                      },
                      "price": {
                        "type": "string",
                        "example": "99017000",
                        "description": "지정가 주문의 주문 가격(주문호가).\n\n시장가 주문은 주문 가격이 표시되지 않습니다."
                      },
                      "qty": {
                        "type": "string",
                        "example": "0.9",
                        "description": "주문 수량 (가상자산). 지정가, BBO 및 시장가 매도 주문에서만 표시되며, BBO 매수 주문에서는 주문 확정 이후 표시됩니다."
                      },
                      "filledQty": {
                        "type": "string",
                        "example": "0.53793136",
                        "description": "체결량 (체결 수량)"
                      },
                      "amt": {
                        "type": "string",
                        "example": "89115300",
                        "description": "주문 대금 (KRW). 시장가 매수 및 BBO 매수 주문에서만 표시됩니다."
                      },
                      "filledAmt": {
                        "type": "string",
                        "example": "53260583.9536",
                        "description": "체결금액"
                      },
                      "avgPrice": {
                        "type": "string",
                        "example": "99010000",
                        "description": "평균 체결 단가"
                      },
                      "createdAt": {
                        "type": "integer",
                        "example": 1700000001000,
                        "description": "주문 접수 시각 (timestamp)"
                      },
                      "lastFilledAt": {
                        "type": "integer",
                        "example": 1700000002000,
                        "description": "마지막 체결 시각 (timestamp)"
                      },
                      "clientOrderId": {
                        "type": "string",
                        "example": "tjcfiDfSjq94giNAat31",
                        "description": "주문 시 입력한 clientOrderId 값"
                      }
                    },
                    "required": [
                      "orderId",
                      "status",
                      "side",
                      "orderType",
                      "timeInForce",
                      "price",
                      "qty",
                      "filledQty",
                      "amt",
                      "filledAmt",
                      "avgPrice",
                      "createdAt",
                      "lastFilledAt",
                      "clientOrderId"
                    ]
                  }
                }
              },
              "required": ["orders"]
            }
          },
          "required": ["symbol", "timestamp", "channelType", "order"]
        },
        "messageId": "korbit.ws.my-order.response"
