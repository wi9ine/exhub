  "components": {
    "messages": {
      "ControlSuccess": {
        "name": "ControlSuccess",
        "title": "제어 메시지 성공 응답",
        "payload": {
          "type": "object",
          "properties": {
            "requestId": {
              "type": "number",
              "description": "요청 메시지에 입력한 requestId 값",
              "example": 1
            },
            "status": {
              "type": "string",
              "description": "제어 메시지 상태",
              "enum": ["success"],
              "example": "success"
            }
          },
          "required": ["requestId", "status"]
        }
      },
      "ControlFail": {
        "name": "ControlFail",
        "title": "제어 메시지 실패 응답",
        "payload": {
          "type": "object",
          "properties": {
            "requestId": {
              "type": "number",
              "description": "요청 메시지에 입력한 requestId 값",
              "example": 1
            },
            "status": {
              "type": "string",
              "description": "제어 메시지 상태",
              "enum": ["fail"],
              "example": "fail"
            },
            "code": {
              "type": "string",
              "description": "오류 코드",
              "example": "INVALID_SYMBOL"
            },
            "message": {
              "type": "string",
              "description": "오류 설명",
              "example": "The symbol does not exist (eth_btc)"
            }
          },
          "required": ["requestId", "status", "code", "message"]
        }
      },
      "ControlError": {
        "name": "ControlError",
        "title": "제어 메시지 오류 응답",
        "payload": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "description": "제어 메시지 상태",
              "enum": ["error"],
              "example": "error"
            },
            "message": {
              "type": "string",
              "description": "오류 설명"
            }
          },
          "required": ["status", "message"]
        }
      },
      "TickerPublicRequest": {
        "name": "TickerPublicRequest",
        "title": "현재가 (Ticker) 요청",
        "payload": {
          "type": "array",
          "description": "웹소켓 구독 요청 메시지 배열. 메시지를 1개만 보낼 때에도 반드시 대괄호([])로 감싸야 합니다.",
          "items": {
            "type": "object",
            "properties": {
              "requestId": {
                "type": "number",
                "description": "임의의 정수 요청 ID. 입력하면 요청 성공/실패 여부와 관계 없이 제어 메시지가 전송됩니다.",
                "example": 1
              },
              "method": {
                "type": "string",
                "description": "고정 값 subscribe 또는 unsubscribe 입력",
                "example": "subscribe"
              },
              "type": {
                "type": "string",
                "description": "고정 값 ticker 입력",
                "example": "ticker"
              },
              "symbols": {
                "type": "array",
                "items": {
                  "type": "string",
                  "example": "btc_krw"
                },
                "description": "조회하고자 하는 거래쌍의 심볼을 입력합니다.",
                "example": ["btc_krw", "eth_krw"]
              }
            },
            "required": ["method", "type", "symbols"]
          },
          "minItems": 1,
          "example": [
            {
              "method": "subscribe",
              "type": "ticker",
              "symbols": ["btc_krw", "eth_krw"]
            }
          ]
        },
        "messageId": "korbit.ws.ticker.request"
      },
      "TickerPublicResponse": {
        "name": "TickerPublicResponse",
        "title": "현재가 (Ticker) 응답",
        "payload": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "example": "ticker",
              "description": "고정 값 ticker"
            },
            "timestamp": {
              "type": "integer",
              "example": 1700000027754,
              "description": "현재 서버 시간 (단위: Unix Timestamp (밀리초))"
            },
            "symbol": {
              "type": "string",
              "example": "btc_krw",
              "description": "거래쌍"
            },
            "snapshot": {
              "type": "boolean",
              "example": true,
              "description": "스냅샷 데이터 여부.\n\ntrue - 구독 요청 직후 최초로 전송되는 메시지로서 요청 당시의 최신 정보를 전송합니다.\n\nfalse 또는 null - 이벤트 발생에 따라 실시간으로 전송되는 메시지입니다."
            },
            "data": {
              "type": "object",
              "properties": {
                "open": {
                  "type": "string",
                  "example": "94679000",
                  "description": "최근 24시간 시가"
                },
                "high": {
                  "type": "string",
                  "example": "111162000",
                  "description": "최근 24시간 고가"
                },
                "low": {
                  "type": "string",
                  "example": "93861000",
                  "description": "최근 24시간 저가"
                },
                "close": {
                  "type": "string",
                  "example": "99027000",
                  "description": "최근 24시간 종가"
                },
                "prevClose": {
                  "type": "string",
                  "example": "94679000",
                  "description": "직전 24시간 종가"
                },
                "priceChange": {
                  "type": "string",
                  "example": "4348000",
                  "description": "직전 종가 대비 가격 변화량. prevClose - close으로 계산합니다."
                },
                "priceChangePercent": {
                  "type": "string",
                  "example": "4.59",
                  "description": "직전 종가 대비 가격 변화율(단위: %). 100 * (prevClose - close) / prevClose으로 계산합니다."
                },
                "volume": {
                  "type": "string",
                  "example": "147.94385655",
                  "description": "최근 24시간 거래량(가상자산)"
                },
                "quoteVolume": {
                  "type": "string",
                  "example": "14311735005.18033",
                  "description": "최근 24시간 거래대금(원화)"
                },
                "bestAskPrice": {
                  "type": "string",
                  "example": "99027000",
                  "description": "매도 1호가"
                },
                "bestBidPrice": {
                  "type": "string",
                  "example": "99026000",
                  "description": "매수 1호가"
                },
                "lastTradedAt": {
                  "type": "integer",
                  "example": 1700000010022,
                  "description": "마지막 체결 시각 (단위: Unix Timestamp (밀리초))"
                }
              },
              "required": [
                "open",
                "high",
                "low",
                "close",
                "prevClose",
                "priceChange",
                "priceChangePercent",
                "volume",
                "quoteVolume",
                "bestAskPrice",
                "bestBidPrice",
                "lastTradedAt"
              ]
            }
          },
          "required": ["type", "timestamp", "symbol", "snapshot", "data"]
        },
        "messageId": "korbit.ws.ticker.response"
      },
      "OrderbookPublicRequest": {
        "name": "OrderbookPublicRequest",
        "title": "호가 (Orderbook) 요청",
        "payload": {
          "type": "array",
          "description": "웹소켓 구독 요청 메시지 배열. 메시지를 1개만 보낼 때에도 반드시 대괄호([])로 감싸야 합니다.",
          "items": {
            "type": "object",
            "properties": {
              "requestId": {
                "type": "number",
                "description": "임의의 정수 요청 ID. 입력하면 요청 성공/실패 여부와 관계 없이 제어 메시지가 전송됩니다.",
                "example": 1
              },
              "method": {
                "type": "string",
                "description": "고정 값 subscribe 또는 unsubscribe 입력",
                "example": "subscribe"
              },
              "type": {
                "type": "string",
                "description": "고정 값 orderbook 입력",
                "example": "orderbook"
              },
              "symbols": {
                "type": "array",
                "items": {
                  "type": "string",
                  "example": "btc_krw"
                },
                "description": "조회하고자 하는 거래쌍의 심볼을 입력합니다.",
                "example": ["btc_krw", "eth_krw"]
              },
              "level": {
                "type": "string",
                "description": "오더북 모아보기 단위. 모아보기 단위는 호가 정책 조회 API로 확인할 수 있습니다. 입력하지 않을 경우 모아보기를 적용하지 않습니다.",
                "example": "1000"
              }
            },
            "required": ["method", "type", "symbols"]
          },
          "minItems": 1,
          "example": [
            {
              "method": "subscribe",
              "type": "orderbook",
              "symbols": ["btc_krw"]
            }
          ]
        },
        "messageId": "korbit.ws.orderbook.request"
      },
      "OrderbookPublicResponse": {
        "name": "OrderbookPublicResponse",
        "title": "호가 (Orderbook) 응답",
        "payload": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "example": "orderbook",
              "description": "고정 값 orderbook"
            },
            "timestamp": {
              "type": "integer",
              "example": 1700000006177,
              "description": "현재 서버 시간 (단위: Unix Timestamp (밀리초))"
            },
            "symbol": {
              "type": "string",
              "example": "btc_krw",
              "description": "거래쌍"
            },
            "snapshot": {
              "type": "boolean",
              "example": true,
              "description": "스냅샷 데이터 여부.\n\ntrue - 구독 요청 직후 최초로 전송되는 메시지로서 요청 당시의 최신 정보를 전송합니다.\n\nfalse 또는 null - 이벤트 발생에 따라 실시간으로 전송되는 메시지입니다."
            },
            "data": {
              "type": "object",
              "properties": {
                "timestamp": {
                  "type": "integer",
                  "example": 1700000000234,
                  "description": "호가 정보의 기준 시각 (단위: Unix Timestamp (밀리초))"
                },
                "asks": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "price": {
                        "type": "string",
                        "example": "99131000",
                        "description": "매도호가"
                      },
                      "qty": {
                        "type": "string",
                        "example": "0.00456677",
                        "description": "매도잔량"
                      },
                      "amt": {
                        "type": "string",
                        "description": "호가 금액 (오더북 모아보기를 사용하는 경우에만 세팅되며, 모아보기를 사용하지 않는 경우 price * qty로 계산할 수 있습니다.)",
                        "example": "2500000"
                      }
                    },
                    "required": ["price", "qty"]
                  },
                  "description": "매도 호가 정보 (호가 오름차순 정렬)"
                },
                "bids": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "price": {
                        "type": "string",
                        "example": "99120000",
                        "description": "매수호가"
                      },
                      "qty": {
                        "type": "string",
                        "example": "0.00363422",
                        "description": "매수잔량"
                      },
                      "amt": {
                        "type": "string",
                        "description": "호가 금액 (오더북 모아보기를 사용하는 경우에만 세팅되며, 모아보기를 사용하지 않는 경우 price * qty로 계산할 수 있습니다.)",
                        "example": "2500000"
                      }
                    },
                    "required": ["price", "qty"]
                  },
                  "description": "매수 호가 정보 (호가 내림차순 정렬)"
                }
              },
              "required": ["timestamp", "asks", "bids"]
            }
          },
