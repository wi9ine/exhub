      "MyOrderPrivateResponse": {
        "name": "MyOrderPrivateResponse",
        "title": "내 주문 (MyOrder) 응답",
        "payload": {
          "type": "object",
          "properties": {
            "symbol": {
              "type": "string",
              "example": "btc_krw",
              "description": "거래쌍"
            },
            "timestamp": {
              "type": "integer",
              "example": 1700000000000,
              "description": "현재 서버 시간 (단위: Unix Timestamp (밀리초))"
            },
