                          "status"
                        ]
                      }
                    }
                  },
                  "required": [
                    "success",
                    "data"
                  ]
                },
                "example": {
                  "success": true,
                  "data": [
                    {
                      "symbol": "btc_krw",
                      "status": "launched"
                    },
                    {
                      "symbol": "eth_krw",
                      "status": "launched"
                    },
                    {
                      "symbol": "xrp_krw",
                      "status": "stopped"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/v2/tickSizePolicy": {
      "get": {
        "tags": [
          "시세"
        ],
