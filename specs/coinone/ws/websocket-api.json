  "components": {
    "schemas": {
      "TopicPair": {
        "type": "object",
        "properties": {
          "quote_currency": {
            "type": "string",
            "description": "마켓 기준 통화"
          },
          "target_currency": {
            "type": "string",
            "description": "조회 요청할 종목"
          }
        },
        "required": [
          "quote_currency",
          "target_currency"
        ]
      },
      "ChartTopic": {
        "type": "object",
        "properties": {
          "quote_currency": {
            "type": "string"
          },
          "target_currency": {
            "type": "string"
          },
          "interval": {
            "type": "string",
            "description": "1m, 3m, 5m, 15m, 30m, 1h, 2h, 4h, 6h, 1d, 1w"
          }
        },
        "required": [
          "quote_currency",
          "target_currency",
          "interval"
        ]
      },
      "PublicBaseRequest": {
        "type": "object",
        "properties": {
          "request_type": {
            "type": "string",
            "enum": [
              "SUBSCRIBE",
              "UNSUBSCRIBE",
              "PING"
            ],
            "description": "실행할 요청 종류"
          },
          "channel": {
            "type": "string",
            "description": "구독 채널명. PING 요청일 경우 생략합니다."
          },
          "topic": {
            "type": "object",
            "description": "quote_currency, target_currency 등의 정보를 담는 topic 오브젝트. PING 요청일 경우 생략합니다."
          },
          "format": {
            "type": "string",
            "enum": [
              "DEFAULT",
              "SHORT"
            ],
            "default": "DEFAULT",
            "description": "단축 변수명으로 구독 원하는 경우 SHORT 입력 (기본값: DEFAULT)"
          }
        },
        "required": [
          "request_type"
        ]
      },
      "PrivateBaseRequest": {
        "type": "object",
        "properties": {
          "request_type": {
            "type": "string",
            "enum": [
              "SUBSCRIBE",
              "UNSUBSCRIBE",
              "PING"
            ],
            "description": "실행할 요청 종류"
          },
          "channel": {
            "type": "string",
            "description": "구독 채널명. PING 요청일 경우 생략합니다."
          },
          "topic": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TopicPair"
            },
            "description": "전체 거래 종목 또는 특정 거래 종목에 대한 topic 목록"
          },
          "format": {
            "type": "string",
            "enum": [
              "DEFAULT",
              "SHORT"
            ],
            "default": "DEFAULT",
            "description": "단축 변수명으로 구독 원하는 경우 SHORT 입력 (기본값: DEFAULT)"
          }
        },
        "required": [
          "request_type"
        ]
      },
      "PingRequest": {
        "type": "object",
        "properties": {
          "request_type": {
            "type": "string",
            "enum": [
              "PING"
            ],
            "description": "연결 상태를 체크하고 세션 만료시간을 갱신하는 요청"
          }
        },
        "required": [
          "request_type"
        ]
      },
      "PongResponse": {
        "type": "object",
        "properties": {
          "response_type": {
            "type": "string",
            "enum": [
              "PONG"
            ],
            "description": "PING 요청에 대한 응답"
          }
        },
        "required": [
          "response_type"
        ]
      },
      "ConnectedResponse": {
        "type": "object",
        "properties": {
          "response_type": {
            "type": "string",
            "enum": [
              "CONNECTED"
            ],
            "description": "웹소켓 연결 직후 세션 생성 성공 응답"
          },
          "data": {
            "type": "object",
            "description": "세션 정보",
            "properties": {
              "session_id": {
                "type": "string",
                "description": "생성된 세션 식별자"
              }
            },
            "required": [
              "session_id"
            ]
          }
        },
        "required": [
          "response_type",
          "data"
        ]
      },
      "PublicOrderbookRequestPayload": {
        "allOf": [
          {
            "$ref": "#/components/schemas/PublicBaseRequest"
          },
          {
            "type": "object",
            "properties": {
              "channel": {
                "type": "string",
                "enum": [
                  "ORDERBOOK"
                ],
                "description": "구독 채널명: ORDERBOOK"
              },
              "topic": {
                "$ref": "#/components/schemas/TopicPair"
              }
            },
            "required": [
              "request_type",
              "channel",
              "topic"
            ]
          }
        ]
      },
      "PublicTickerRequestPayload": {
        "allOf": [
          {
            "$ref": "#/components/schemas/PublicBaseRequest"
          },
          {
            "type": "object",
            "properties": {
              "channel": {
                "type": "string",
                "enum": [
                  "TICKER"
                ],
                "description": "구독 채널명: TICKER"
              },
              "topic": {
                "$ref": "#/components/schemas/TopicPair"
              }
            },
            "required": [
              "request_type",
              "channel",
              "topic"
            ]
          }
        ]
      },
      "PublicTradeRequestPayload": {
        "allOf": [
          {
            "$ref": "#/components/schemas/PublicBaseRequest"
          },
          {
            "type": "object",
            "properties": {
              "channel": {
                "type": "string",
                "enum": [
                  "TRADE"
                ],
                "description": "구독 채널명: TRADE"
              },
              "topic": {
                "$ref": "#/components/schemas/TopicPair"
              }
            },
            "required": [
              "request_type",
              "channel",
              "topic"
            ]
          }
        ]
      },
      "PublicChartRequestPayload": {
        "allOf": [
          {
            "$ref": "#/components/schemas/PublicBaseRequest"
          },
          {
            "type": "object",
            "properties": {
              "channel": {
                "type": "string",
                "enum": [
                  "CHART"
                ],
                "description": "구독 채널명: CHART"
              },
              "topic": {
                "$ref": "#/components/schemas/ChartTopic"
              }
            },
            "required": [
              "request_type",
              "channel",
              "topic"
            ]
          }
        ]
      },
      "PrivateMyOrderRequestPayload": {
        "allOf": [
          {
            "$ref": "#/components/schemas/PrivateBaseRequest"
          },
          {
            "type": "object",
            "properties": {
              "channel": {
                "type": "string",
                "enum": [
                  "MYORDER"
                ],
                "description": "구독 채널명: MYORDER"
              }
            },
            "required": [
              "request_type",
              "channel"
            ]
          }
        ]
      },
      "PrivateMyAssetRequestPayload": {
        "allOf": [
          {
            "$ref": "#/components/schemas/PrivateBaseRequest"
          },
          {
            "type": "object",
            "properties": {
              "channel": {
                "type": "string",
                "enum": [
                  "MYASSET"
                ],
                "description": "구독 채널명: MYASSET"
              }
            },
            "required": [
              "request_type",
              "channel"
            ]
          }
        ]
      },
      "SubscribedBase": {
        "type": "object",
        "properties": {
          "response_type": {
            "type": "string",
            "enum": [
              "SUBSCRIBED"
            ]
          },
          "channel": {
            "type": "string"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "response_type",
          "channel"
        ]
      },
      "PublicOrderbookStreamData": {
        "type": "object",
        "properties": {
          "quote_currency": {
            "type": "string",
            "x-abbreviation": "qc",
            "description": "마켓 기준 통화 (예: KRW)"
          },
          "target_currency": {
            "type": "string",
            "x-abbreviation": "tc",
            "description": "조회한 종목의 심볼 (예: BTC)"
          },
          "timestamp": {
            "type": "integer",
            "format": "int64",
            "x-abbreviation": "t",
            "description": "타임스탬프 (millisecond)"
          },
          "id": {
            "type": "string",
            "x-abbreviation": "i",
            "description": "order book id 값, id 값이 클수록 최신 OrderBook 정보"
          },
          "asks": {
            "type": "array",
            "x-abbreviation": "a",
            "items": {
              "type": "object",
              "properties": {
                "price": {
                  "type": "string",
                  "x-abbreviation": "p",
                  "description": "매도 호가"
                },
                "qty": {
                  "type": "string",
                  "x-abbreviation": "q",
                  "description": "매도 수량"
                }
              },
              "required": [
                "price",
                "qty"
              ]
            },
            "description": "매도 오더북 정보"
          },
          "bids": {
            "type": "array",
            "x-abbreviation": "b",
            "items": {
              "type": "object",
              "properties": {
                "price": {
                  "type": "string",
                  "x-abbreviation": "p",
                  "description": "매수 호가"
                },
                "qty": {
                  "type": "string",
                  "x-abbreviation": "q",
                  "description": "매수 수량"
                }
              },
              "required": [
                "price",
                "qty"
              ]
            },
            "description": "매수 오더북 정보"
          }
        },
        "required": [
          "quote_currency",
          "target_currency",
          "timestamp",
          "id",
          "asks",
          "bids"
        ],
        "x-format-transforms": {
          "SHORT": "DEFAULT 객체의 각 키를 x-abbreviation 값으로 치환"
        },
        "description": "구독 data 정보"
      },
      "PublicOrderbookDataPayload": {
        "type": "object",
        "properties": {
          "response_type": {
            "type": "string",
            "enum": [
              "DATA"
            ],
            "x-abbreviation": "r",
            "description": "실시간 데이터 응답을 의미하며 DATA로 고정"
          },
          "channel": {
            "type": "string",
            "enum": [
              "ORDERBOOK"
            ],
            "x-abbreviation": "c",
            "description": "ORDERBOOK 채널 고정"
          },
          "data": {
            "$ref": "#/components/schemas/PublicOrderbookStreamData",
            "x-abbreviation": "d",
            "description": "구독 data 정보"
          }
        },
        "required": [
          "response_type",
          "channel",
          "data"
        ]
      },
      "PublicTickerStreamData": {
        "type": "object",
        "properties": {
          "quote_currency": {
            "type": "string",
            "x-abbreviation": "qc",
            "description": "마켓 기준 통화"
          },
          "target_currency": {
            "type": "string",
            "x-abbreviation": "tc",
            "description": "조회한 종목의 심볼"
          },
          "timestamp": {
            "type": "integer",
            "format": "int64",
            "x-abbreviation": "t",
            "description": "티커 생성 시점 (Unix time) (ms)"
          },
          "quote_volume": {
            "type": "string",
            "x-abbreviation": "qv",
            "description": "최근 24시간 기준 종목 체결 금액 (원화)"
          },
          "target_volume": {
            "type": "string",
            "x-abbreviation": "tv",
            "description": "최근 24시간 기준 종목 체결량 (종목)"
          },
          "high": {
            "type": "string",
            "x-abbreviation": "hi",
            "description": "고가"
          },
          "low": {
            "type": "string",
            "x-abbreviation": "lo",
            "description": "저가"
          },
          "first": {
            "type": "string",
            "x-abbreviation": "fi",
            "description": "시가"
          },
          "last": {
            "type": "string",
            "x-abbreviation": "la",
