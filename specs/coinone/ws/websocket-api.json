          "$ref": "#/components/messages/PublicPingRequest"
        },
        "externalDocs": {
          "description": "공식 문서",
          "url": "https://docs.coinone.co.kr/reference/public-websocket-ping"
        },
        "x-doc-url": "https://docs.coinone.co.kr/reference/public-websocket-ping"
      },
      "subscribe": {
        "operationId": "receive-public-pong",
        "message": {
          "$ref": "#/components/messages/PublicPongResponse"
        },
        "externalDocs": {
          "description": "공식 문서",
          "url": "https://docs.coinone.co.kr/reference/public-websocket-ping"
