    "/trading-pairs/{TradingPair}/candles": {
      "get": {
        "tags": ["공개 API"],
        "summary": "차트 데이터 조회",
        "description": "1개의 구간은 1개의 차트 봉과 일치합니다.",
        "operationId": "get-trading-pair-candles",
        "externalDocs": {
          "description": "공식 문서",
          "url": "https://gopax.github.io/API/index.html#10f99c8763"
        },
        "x-doc-url": "https://gopax.github.io/API/index.html#10f99c8763",
        "responses": {
          "200": {
            "description": "성공",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "array",
                    "items": {
                      "type": "integer",
                      "example": 1601032200000,
                      "description": "구간 누적 거래량 (base 자산 단위로 이 예시에서는 BTC)"
                    }
                  }
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "TradingPair",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "거래쌍 (예: BTC-KRW)"
          },
          {
            "name": "start",
            "in": "query",
            "required": true,
            "description": "시작 시점 타임스탬프 (밀리세컨드 단위)",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "end",
            "in": "query",
            "required": true,
            "description": "종료 시점 타임스탬프 (밀리세컨드 단위)",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "interval",
            "in": "query",
            "required": true,
            "description": "캔들 시간 간격 (분 단위): 1, 5, 30, 1440 중 하나",
            "schema": {
              "type": "integer",
