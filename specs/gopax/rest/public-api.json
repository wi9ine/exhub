{
  "openapi": "3.0.3",
  "info": {
    "title": "GOPAX Public REST API",
    "version": "1.0.0",
    "description": "고팍스 공식 문서 기준 스펙입니다.",
    "contact": {
      "name": "GOPAX API Docs",
      "url": "https://gopax.github.io/API/index.html"
    }
  },
  "servers": [
    {
      "url": "https://api.gopax.co.kr"
    }
  ],
  "tags": [
    {
      "name": "공개 API"
    }
  ],
  "paths": {
    "/assets": {
      "get": {
        "tags": ["공개 API"],
        "summary": "자산 목록 조회",
        "operationId": "list-assets",
        "externalDocs": {
          "description": "공식 문서",
          "url": "https://gopax.github.io/API/index.html#f55085599b"
        },
        "x-doc-url": "https://gopax.github.io/API/index.html#f55085599b",
        "responses": {
          "200": {
            "description": "성공",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string",
                        "example": "ETH",
                        "description": "자산 이름"
                      },
                      "name": {
                        "type": "string",
                        "example": "이더리움",
                        "description": "자산 이름 (국문)"
                      },
                      "englishName": {
                        "type": "string",
                        "example": "Ethereum",
                        "description": "자산 이름 (영문)"
                      },
                      "scale": {
                        "type": "integer",
                        "example": 8,
                        "description": "자산 최대 소수점 자리수"
                      },
                      "withdrawalFee": {
                        "type": "number",
                        "example": 0.03,
                        "description": "출금 수수료"
                      },
                      "withdrawalAmountMin": {
                        "type": "number",
                        "example": 0.015,
                        "description": "출금 최소 금액"
                      }
                    },
                    "required": [
                      "id",
                      "name",
                      "englishName",
                      "scale",
                      "withdrawalFee",
                      "withdrawalAmountMin"
                    ]
                  }
                }
              }
            }
          }
        }
      }
    },
    "/trading-pairs": {
      "get": {
        "tags": ["공개 API"],
        "summary": "거래쌍 목록 조회",
        "operationId": "list-trading-pairs",
        "externalDocs": {
          "description": "공식 문서",
          "url": "https://gopax.github.io/API/index.html#bd57884325"
        },
        "x-doc-url": "https://gopax.github.io/API/index.html#bd57884325",
        "responses": {
          "200": {
            "description": "성공",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "integer",
                        "example": 1,
                        "description": "거래쌍 ID"
                      },
                      "name": {
                        "type": "string",
                        "example": "ETH-KRW",
                        "description": "거래쌍 이름"
                      },
                      "baseAsset": {
                        "type": "string",
                        "example": "ETH",
                        "description": "base 자산"
                      },
                      "quoteAsset": {
                        "type": "string",
                        "example": "KRW",
                        "description": "quote 자산"
                      },
                      "baseAssetScale": {
                        "type": "integer",
                        "example": 8,
                        "description": "base 자산 최대 소수점 자리수"
                      },
                      "quoteAssetScale": {
                        "type": "integer",
                        "example": 0,
                        "description": "quote 자산 최대 소수점 자리수"
                      },
                      "priceMin": {
                        "type": "integer",
                        "example": 1,
                        "description": "최소 주문 가격"
                      },
                      "restApiOrderAmountMin": {
                        "type": "object",
                        "properties": {
                          "limitAsk": {
                            "type": "object",
                            "properties": {
                              "amount": {
                                "type": "integer",
                                "example": 1000
                              },
                              "unit": {
                                "type": "string",
                                "example": "KRW"
                              }
                            },
                            "required": ["amount", "unit"]
                          },
                          "limitBid": {
                            "type": "object",
                            "properties": {
                              "amount": {
                                "type": "integer",
                                "example": 1000
                              },
                              "unit": {
                                "type": "string",
                                "example": "KRW"
                              }
                            },
                            "required": ["amount", "unit"]
                          },
                          "marketAsk": {
                            "type": "object",
                            "properties": {
                              "amount": {
                                "type": "number",
                                "example": 0.001
                              },
                              "unit": {
                                "type": "string",
                                "example": "ETH"
                              }
                            },
                            "required": ["amount", "unit"]
                          },
                          "marketBid": {
                            "type": "object",
                            "properties": {
                              "amount": {
                                "type": "integer",
                                "example": 1000
                              },
                              "unit": {
                                "type": "string",
                                "example": "KRW"
                              }
                            },
                            "required": ["amount", "unit"]
                          }
                        },
                        "required": ["limitAsk", "limitBid", "marketAsk", "marketBid"],
                        "description": "REST API 통해 주문 시 최소 주문 수량"
                      },
                      "makerFeePercent": {
                        "type": "number",
                        "example": 0.2,
                        "description": "메이커 거래 수수료 퍼센트"
                      },
                      "takerFeePercent": {
                        "type": "number",
                        "example": 0.2,
                        "description": "테이커 거래 수수료 퍼센트"
                      }
                    },
                    "required": [
                      "id",
                      "name",
                      "baseAsset",
                      "quoteAsset",
                      "baseAssetScale",
                      "quoteAssetScale",
                      "priceMin",
                      "restApiOrderAmountMin",
                      "makerFeePercent",
                      "takerFeePercent"
                    ]
                  }
                }
              }
            }
          }
        }
      }
    },
    "/trading-pairs/{TradingPair}/price-tick-size": {
      "get": {
        "tags": ["공개 API"],
        "summary": "가격 틱 사이즈 조회",
        "operationId": "get-trading-pair-price-tick-size",
        "externalDocs": {
          "description": "공식 문서",
          "url": "https://gopax.github.io/API/index.html#8cbaa14a64"
        },
        "x-doc-url": "https://gopax.github.io/API/index.html#8cbaa14a64",
        "responses": {
          "200": {
            "description": "성공",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "startPrice": {
                        "type": "integer",
                        "example": 1
                      },
                      "tickSize": {
                        "type": "integer",
                        "example": 1
                      }
                    },
                    "required": ["startPrice", "tickSize"]
                  }
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "TradingPair",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "거래쌍 (예: BTC-KRW)"
          }
        ]
      }
    },
    "/trading-pairs/{TradingPair}/ticker": {
      "get": {
        "tags": ["공개 API"],
        "summary": "티커 조회",
        "operationId": "get-trading-pair-ticker",
        "externalDocs": {
          "description": "공식 문서",
          "url": "https://gopax.github.io/API/index.html#c63d14aba7"
        },
        "x-doc-url": "https://gopax.github.io/API/index.html#c63d14aba7",
        "responses": {
          "200": {
            "description": "성공",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "price": {
                      "type": "integer",
                      "example": 15393000,
                      "description": "오더북 상의 현재 가격"
                    },
                    "ask": {
                      "type": "integer",
                      "example": 15397000,
                      "description": "오더북 상의 현재 가장 낮은 매도 가격"
                    },
                    "askVolume": {
                      "type": "number",
                      "example": 0.56,
                      "description": "오더북 상의 현재 가장 낮은 매도 가격의 수량"
                    },
                    "bid": {
                      "type": "integer",
                      "example": 15393000,
                      "description": "오더북 상의 현재 가장 높은 매수 가격"
                    },
                    "bidVolume": {
                      "type": "number",
                      "example": 1.9513,
                      "description": "오더북 상의 현재 가장 높은 매수 가격의 수량"
                    },
                    "volume": {
                      "type": "number",
                      "example": 487.43035427,
                      "description": "최근 24시간 누적 거래량 (base 자산 단위로 이 예시에서는 BTC)"
                    },
                    "quoteVolume": {
                      "type": "number",
                      "example": 7319576689.34135,
                      "description": "최근 24시간 누적 거래량 (quote 자산 단위로 이 예시에서는 KRW)"
                    },
                    "time": {
                      "type": "string",
                      "example": "2020-10-28T02:05:55.958Z",
                      "description": "티커 최근 갱신 시간"
                    }
                  },
                  "required": [
                    "price",
                    "ask",
                    "askVolume",
                    "bid",
                    "bidVolume",
                    "volume",
                    "quoteVolume",
                    "time"
                  ]
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "TradingPair",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "거래쌍 (예: BTC-KRW)"
          }
        ]
      }
    },
    "/trading-pairs/{TradingPair}/book": {
      "get": {
        "tags": ["공개 API"],
        "summary": "오더북 조회",
        "operationId": "get-trading-pair-book",
        "externalDocs": {
          "description": "공식 문서",
          "url": "https://gopax.github.io/API/index.html#6ad081727e"
        },
        "x-doc-url": "https://gopax.github.io/API/index.html#6ad081727e",
        "responses": {
          "200": {
            "description": "성공",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "sequence": {
                      "type": "integer",
                      "example": 110815766
                    },
                    "ask": {
                      "type": "array",
                      "items": {
                        "type": "array",
                        "items": {
                          "type": "string",
                          "example": "110815528",
                          "description": "오더북 엔트리 업데이트 시간"
                        }
                      },
                      "description": "오더북 판매 엔트리 목록"
                    },
                    "bid": {
                      "type": "array",
                      "items": {
                        "type": "array",
                        "items": {
                          "type": "string",
                          "example": "108223577"
                        }
                      },
                      "description": "오더북 구매 엔트리 목록"
                    }
                  },
                  "required": ["sequence", "ask", "bid"]
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "TradingPair",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "거래쌍 (예: BTC-KRW)"
          },
          {
            "name": "level",
            "in": "query",
            "required": false,
            "description": "오더북 레벨. 1 = 1개 호가, 2 = 50개 호가, 3 = 전체 오더북",
            "schema": {
              "type": "integer",
              "enum": [1, 2, 3]
            }
          }
        ]
      }
    },
    "/trading-pairs/{TradingPair}/trades": {
      "get": {
        "tags": ["공개 API"],
        "summary": "체결 기록 조회",
        "operationId": "list-trading-pair-trades",
        "externalDocs": {
          "description": "공식 문서",
          "url": "https://gopax.github.io/API/index.html#c3c0208b04-2"
        },
        "x-doc-url": "https://gopax.github.io/API/index.html#c3c0208b04-2",
        "responses": {
          "200": {
            "description": "성공",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "time": {
                        "type": "string",
                        "example": "2020-09-25T11:10:29.000Z",
                        "description": "체결 시간"
                      },
                      "date": {
                        "type": "integer",
                        "example": 1601032229,
                        "description": "체결 시간 초 단위 타임스탬프"
                      },
                      "id": {
                        "type": "integer",
                        "example": 21876490,
                        "description": "체결 이벤트 ID"
                      },
                      "price": {
                        "type": "integer",
                        "example": 12353000,
                        "description": "체결 가격"
                      },
                      "amount": {
                        "type": "number",
                        "example": 0.2951,
                        "description": "체결 수량 (base 자산 단위로 이 예시에서는 BTC)"
                      },
                      "side": {
                        "type": "string",
                        "example": "sell",
                        "description": "buy(구매), sell(판매)"
                      }
                    },
                    "required": ["time", "date", "id", "price", "amount", "side"]
                  }
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "TradingPair",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "거래쌍 (예: BTC-KRW)"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "반환되는 항목의 개수 (최대 100)",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "pastmax",
            "in": "query",
            "required": false,
            "description": "이 ID보다 오래된 데이터를 조회",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "latestmin",
            "in": "query",
            "required": false,
            "description": "이 ID보다 새로운 최신 데이터를 조회",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "after",
            "in": "query",
            "required": false,
            "description": "이 타임스탬프 이후의 데이터를 조회 (초 단위)",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "before",
            "in": "query",
            "required": false,
            "description": "이 타임스탬프 이전의 데이터를 조회 (초 단위)",
            "schema": {
              "type": "integer"
            }
          }
        ]
      }
    },
    "/trading-pairs/{TradingPair}/stats": {
      "get": {
        "tags": ["공개 API"],
        "summary": "최근 24시간 통계 조회",
        "operationId": "get-trading-pair-stats",
        "externalDocs": {
          "description": "공식 문서",
          "url": "https://gopax.github.io/API/index.html#24"
        },
        "x-doc-url": "https://gopax.github.io/API/index.html#24",
        "responses": {
          "200": {
            "description": "성공",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "open": {
                      "type": "integer",
                      "example": 12132000,
                      "description": "24시간 전 가격"
                    },
                    "high": {
                      "type": "integer",
                      "example": 12543000,
                      "description": "최근 24시간 동안 최고가"
                    },
                    "low": {
                      "type": "integer",
                      "example": 12059000,
                      "description": "최근 24시간 동안 최저가"
                    },
                    "close": {
                      "type": "integer",
                      "example": 12349000,
                      "description": "현재 가격 (1분마다 갱신됨)"
                    },
                    "volume": {
                      "type": "number",
                      "example": 332.12915604,
                      "description": "최근 24시간 누적 거래량 (base 자산 단위로 이 예시에서는 BTC)"
                    },
                    "time": {
                      "type": "string",
                      "example": "2020-09-25T11:13:47.371Z",
                      "description": "최근 통계 업데이트 시간"
                    }
                  },
                  "required": ["open", "high", "low", "close", "volume", "time"]
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "TradingPair",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "거래쌍 (예: BTC-KRW)"
          }
        ]
      }
    },
