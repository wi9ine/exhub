  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "REST API와 동일하게 Authorization 헤더로 JWT 인증을 진행합니다."
      }
    },
    "schemas": {
      "TicketObject": {
        "type": "object",
        "properties": {
          "ticket": {
            "type": "string",
            "description": "요청자를 식별할 수 있는 값"
          }
        },
        "required": [
          "ticket"
        ]
      },
      "FormatObject": {
        "type": "object",
        "properties": {
          "format": {
            "type": "string",
            "enum": [
              "DEFAULT",
              "SIMPLE"
            ],
            "default": "DEFAULT",
            "description": "DEFAULT는 기본형, SIMPLE은 축약형 포맷"
          }
        },
        "required": [
          "format"
        ]
      },
      "TickerTypeField": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "ticker"
            ]
          },
          "codes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "description": "마켓 코드 리스트. 대문자만 허용"
          },
          "isOnlySnapshot": {
            "type": "boolean",
            "default": false
          },
          "isOnlyRealtime": {
            "type": "boolean",
            "default": false
          }
        },
        "required": [
          "type",
          "codes"
        ]
      },
      "TradeTypeField": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "trade"
            ]
          },
          "codes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "isOnlySnapshot": {
            "type": "boolean",
            "default": false
          },
          "isOnlyRealtime": {
            "type": "boolean",
            "default": false
          }
        },
        "required": [
          "type",
          "codes"
        ]
      },
      "OrderbookTypeField": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "orderbook"
            ]
          },
          "codes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "level": {
            "type": "number",
            "default": 1,
            "description": "모아보기 단위"
          },
          "isOnlySnapshot": {
            "type": "boolean",
            "default": false
          },
          "isOnlyRealtime": {
            "type": "boolean",
            "default": false
          }
        },
        "required": [
          "type",
          "codes"
        ]
      },
      "MyOrderTypeField": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "myOrder"
            ]
          },
          "codes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "생략하거나 빈 배열이면 모든 마켓 수신"
          }
        },
        "required": [
          "type"
        ]
      },
      "MyAssetTypeField": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "myAsset"
            ]
          }
        },
        "required": [
          "type"
        ],
        "additionalProperties": false
      },
      "TickerRequest": {
        "type": "array",
        "items": [
          {
            "$ref": "#/components/schemas/TicketObject"
          },
          {
            "$ref": "#/components/schemas/TickerTypeField"
          }
        ],
        "additionalItems": {
          "$ref": "#/components/schemas/FormatObject"
        },
        "minItems": 2,
        "maxItems": 3
      },
      "TradeRequest": {
        "type": "array",
