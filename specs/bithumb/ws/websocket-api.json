      "url": "wss://ws-api.bithumb.com/websocket/v1",
      "protocol": "wss",
      "description": "Public WebSocket endpoint",
      "bindings": {
        "ws": {}
      }
    },
    "private": {
      "url": "wss://ws-api.bithumb.com/websocket/v1/private",
